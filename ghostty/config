# Text
font-family = "Operator Mono"
font-style = Book
font-style-bold = Bold
font-style-italic = Book Italic
font-style-bold-italic = Bold Italic
font-size = 14

# Tokyo Night Storm color palette
background = 24283b
foreground = a9b1d6
cursor-color = c0caf5

# Themes
config-file = "themes/tokyo-night-storm"

# Window
title = 👻
macos-titlebar-style = tabs
window-padding-x = 16
window-padding-y = 8
window-width = 197
window-height = 53
macos-titlebar-style = transparent

# Other
copy-on-select = clipboard
keybind = shift+enter=text:\n
